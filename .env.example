# Neo4j Configuration
# Internal compose default: bolt://neo4j:7687
# Public API + private company Neo4j: set private URI, e.g. neo4j://10.20.30.40:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_strong_password_here
# Used by neo4j service in docker-compose.yml
NEO4J_AUTH=neo4j/your_strong_password_here

# AI Provider Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://your-domain.com
OPENROUTER_APP_NAME=rag-semantic-inference

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Chainlit frontend -> API base URL
# Local: http://127.0.0.1:5001
# Public: https://api.your-domain.com
API_HOST=http://127.0.0.1:5001
